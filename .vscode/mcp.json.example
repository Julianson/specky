{
  // Specky MCP Server — VS Code Configuration (v3.2.0)
  // Copy this file to .vscode/mcp.json to enable Specky in VS Code with GitHub Copilot.
  //
  // Prerequisites:
  //   npm install -g specky-sdd    (recommended — installs once, runs offline)
  //
  // Alternative (no global install, downloads on every run):
  //   Replace "command": "specky-sdd" with "command": "npx", "args": ["-y", "specky-sdd"]
  //
  // Usage:
  //   In Copilot Chat, type @spec-engineer to start the SDD pipeline.
  //   The agent will call Specky MCP tools to create spec files in your workspace.

  "servers": {
    "specky": {
      "command": "specky-sdd",
      "env": {
        "SDD_WORKSPACE": "${workspaceFolder}"
      }
    }
  }
}
