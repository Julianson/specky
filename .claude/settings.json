{
  "permissions": {
    "allow": [
      "Read(//Users/paulasilva/**)",
      "Bash(git rm:*)",
      "Bash(find /Users/paulasilva -maxdepth 3 -name *.code-workspace)",
      "Bash(ls /Users/paulasilva/Documents/1A_GBB_Customer_Engagements/workspaces/specky/*.code-workspace)"
    ],
    "additionalDirectories": [
      "/Users/paulasilva/Documents/1A_GBB_Customer_Engagements/workspaces/specky/.vscode",
      "/Users/paulasilva/Library/Application Support/Code - Insiders/User",
      "/Users/paulasilva/Library/Application Support/Code/User"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/spec-sync.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-docs.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/srp-validator.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/security-scan.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/changelog.sh\""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-test.sh\""
          }
        ]
      }
    ]
  }
}
