{
  "github.copilot.chat.hooks": {
    "PreToolUse": [
      {
        "matcher": "sdd_create_pr",
        "hooks": [
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/security-scan.sh", "timeout": 30000 },
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/release-gate.sh", "timeout": 15000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|sdd_write_spec|sdd_write_design|sdd_write_tasks",
        "hooks": [
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/spec-sync.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/auto-checkpoint.sh", "timeout": 5000 }
        ]
      },
      {
        "matcher": "sdd_write_spec|sdd_turnkey_spec",
        "hooks": [
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/spec-quality.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/ears-validator.sh", "timeout": 10000 }
        ]
      },
      {
        "matcher": "sdd_write_tasks",
        "hooks": [
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/task-tracer.sh", "timeout": 10000 }
        ]
      },
      {
        "matcher": "sdd_run_analysis|sdd_cross_analyze|sdd_compliance_check",
        "hooks": [
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/drift-monitor.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/cognitive-debt-alert.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .github/plugin/specky/hooks/scripts/metrics-dashboard.sh", "timeout": 5000 }
        ]
      }
    ]
  }
}
